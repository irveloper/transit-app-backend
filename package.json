{
  "name": "transit-backend-app",
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "NODE_ENV=production tsx src/index.ts",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "build": "prisma generate && pnpm run typecheck"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@langchain/core": "^1.1.36",
    "@langchain/openai": "^1.3.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@prisma/config": "^7.5.0",
    "dotenv": "^17.3.1",
    "hono": "^4.12.9",
    "langchain": "^1.2.37",
    "openai": "^6.32.0",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma"
    ]
  }
}
